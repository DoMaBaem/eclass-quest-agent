# ================================================================
# 선택 설정: 다른 MySQL을 사용할 때만 작성
# 기본 Docker MySQL은 run.sh가 주소를 자동으로 설정합니다.
# ================================================================

MYSQL_URL=


# ================================================================
# 외부 서비스 설정
# 기본 주소를 그대로 사용한다면 수정하지 않아도 됩니다.
# ================================================================

OLLAMA_URL=http://localhost:11434/api/chat

ECLASS_BASE_URL=https://learn.hansung.ac.kr
ECLASS_DEFAULT_LANGUAGE=ko


# ================================================================
# 로그인 세션 저장 설정
# 모델·OpenAI API 키·E-Class 계정은 최초 실행 시 입력합니다.
# 암호화 키를 비워 두면 로컬 키 파일이 자동 생성됩니다.
# ================================================================

ECLASS_STORAGE_STATE_ENCRYPTED=data/sessions/eclass_state.enc
ECLASS_SESSION_ENCRYPTION_KEY=
ECLASS_SESSION_KEY_PATH=data/sessions/.eclass_state.key


# ================================================================
# 자동 동기화 설정
# ================================================================

ECLASS_SYNC_ON_STARTUP=true
ECLASS_SYNC_INTERVAL_MINUTES=30


# ================================================================
# 다운로드·감사 로그 저장 설정
# 다운로드 파일 보존 기간은 코드에서 24시간으로 고정됩니다.
# ================================================================

DOWNLOAD_ROOT=data/downloads
DOWNLOAD_MAX_BYTES=52428800
WORKFLOW_AUDIT_PATH=data/audit/workflow.jsonl
